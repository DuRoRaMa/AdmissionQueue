{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "index.ts",
    "handlers/**/*.ts",
    "services/**/*.ts"
  ],
  "exclude": [
    "node_modules",
  ]
}